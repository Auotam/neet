# Copy to .env.local for local dev (never commit .env.local)

# — Maintenance mode (optional) —
# When MAINTENANCE_MODE=true, all visitors see /maintenance unless they POST
# the correct MAINTENANCE_PASSWORD to /api/maintenance-unlock (sets httpOnly cookie).
# Set these in Vercel → Project → Settings → Environment Variables.
# MAINTENANCE_MODE=true
# MAINTENANCE_PASSWORD=
# Optional: separate secret for cookie HMAC (defaults to password + internal salt)
# MAINTENANCE_COOKIE_SECRET=

# — Subpath hosting (optional) —
# NEXT_BASE_PATH=/neet
